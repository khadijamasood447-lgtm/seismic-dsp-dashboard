{
  "provider": "anthropic",
  "default_model": "claude-3-sonnet-20240229",
  "quality_model": "claude-3-sonnet-20241022",
  "rate_limit": {
    "requests_per_minute_per_ip": 10
  },
  "max_tokens": 800,
  "cache": {
    "enabled": true,
    "notes": "In-memory cache of predictions/test points; conversation memory stores last 10 messages per conversation_id."
  },
  "data_paths": {
    "aoi_predictions": "../outputs/predictions_vs/aoi_vs_predictions.csv",
    "test_points": "../outputs/predictions_vs/islamabad_test_points_clean.csv",
    "metrics": "../outputs/metrics_vs/validation_report.json"
  }
}

